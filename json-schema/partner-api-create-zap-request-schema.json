{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CreateZapRequest",
  "description": "See our Building a Zap guide to get started.",
  "$id": "https://raw.githubusercontent.com/api-evangelist/zapier/refs/heads/main/json-schema/partner-api-create-zap-request-schema.json",
  "type": "object",
  "properties": {
    "steps": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/CreateZapRequestStep"
      },
      "description": "The list of steps that the Zap should consist of",
      "example": [
        {}
      ]
    },
    "title": {
      "type": "string",
      "description": "The title to be set for this Zap",
      "example": "Example Name"
    }
  },
  "required": [
    "steps",
    "title"
  ]
}