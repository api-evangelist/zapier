{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/zapier/refs/heads/main/json-structure/partner-api-info-field-structure.json",
  "name": "InfoField",
  "description": "Represents an Info-type Fieldset",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "readOnly": true,
      "description": "The type of this Info Field",
      "example": "standard"
    },
    "id": {
      "type": "string",
      "description": "The identifier of this Info Field",
      "example": "500123"
    },
    "description": {
      "type": "string",
      "description": "The description for this Info Field",
      "example": "Example description for this resource."
    }
  },
  "required": [
    "description",
    "id",
    "type"
  ]
}